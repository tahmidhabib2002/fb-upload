# ============================================================
# Google OAuth Credentials (for login system)
# ============================================================
# Get these from https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Set Authorized redirect URIs to: http://localhost:3000/api/auth/google/callback
# For production, use your actual domain
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ============================================================
# Authentication
# ============================================================
# IMPORTANT: Set this to the email address that is allowed to log in
# Only this email will be able to access the dashboard
ALLOWED_EMAIL=your-email@example.com

# ============================================================
# Supabase Configuration
# ============================================================
# Get these from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://vinlrfcbohsrvumoidbj.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_bsLAsH0xiIyXmJtFkw8bCg_7PWpMKgr

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=development

# IMPORTANT: For production, set this to your actual domain
# This is used for Facebook OAuth redirect
APP_BASE_URL=http://localhost:3000

# ============================================================
# Facebook API Version
# ============================================================
FB_API_VERSION=v19.0

# ============================================================
# Upload Configuration
# ============================================================
# Chunk size in bytes for resumable uploads (default: 10MB)
CHUNK_SIZE=10485760

# Max concurrent uploads to avoid Facebook rate limits
MAX_CONCURRENT_UPLOADS=3

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. NEVER commit this file to version control
# 2. Add .env to your .gitignore
# 3. For production, use environment variables directly
# 4. Rotate your App Secret if it is ever exposed
# 5. Always use HTTPS in production
# 6. Change the session secret in server.js to something unique

